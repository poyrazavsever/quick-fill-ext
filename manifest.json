{
  "manifest_version": 3,
  "name": "Shortcut Injector",
  "version": "1.0.0",
  "description": "Inject saved values into form fields with shortcuts and aliases.",
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "index.html",
    "default_title": "Shortcut Injector",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "shortcut-injector@local.dev"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ]
}
