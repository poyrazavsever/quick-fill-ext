{
  "manifest_version": 3,
  "name": "Quick Fill Extension",
  "version": "1.0.0",
  "description": "A Chrome extension to quickly fill forms with predefined data.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "index.html",
    "default_title": "Quick Fill"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ]
}
